<!DOCTYPE html>
<html>
<head>
<title>Workshop Event</title>

<style>

body{
    font-family: Arial, sans-serif;
    background-color: lightblue;
}

.container{
    width: 60%;
    margin: auto;
    background-color: white;
    padding: 20px;
    border-radius: 10px;
}

h1{
    color: darkblue;
}

h2{
    color: darkgreen;
}

input, select, textarea{
    width: 100%;
    padding: 8px;
    margin-top: 5px;
}

select{
    appearance: none;
    background-color: #f0f0f0;
    border: 1px solid gray;
}

button{
    padding: 8px 15px;
    margin-top: 10px;
}

.submit{
    background-color: green;
    color: white;
}

.reset{
    background-color: red;
    color: white;
}

</style>

</head>

<body>

<div class="container">

<center>
<h1>Web Development Workshop</h1>
<h3>Organized by Computer Application Department</h3>
<hr>
</center>

<h2>Event Details</h2>
<p><b>Date:</b> 20 March 2026</p>
<p><b>Time:</b> 9:30 AM to 3:30 PM</p>
<p><b>Venue:</b> College Auditorium</p>

<h2>Registration Form</h2>

<form>

Full Name:<br>
<input type="text"><br><br>

Email:<br>
<input type="email"><br><br>

Phone Number:<br>
<input type="tel"><br><br>

Gender:<br>
<input type="radio" name="gender"> Male
<input type="radio" name="gender" checked> Female
<br><br>

Select Course:<br>
<select>
<option>HTML</option>
<option>CSS</option>
<option>JavaScript</option>
</select>
<br><br>

Address:<br>
<textarea rows="4"></textarea>
<br><br>

<button type="submit" class="submit">Register</button>
<button type="reset" class="reset">Clear</button>

</form>

<hr>

<center>
<p>© 2026 Workshop Event</p>
</center>

</div>

</body>
</html>
