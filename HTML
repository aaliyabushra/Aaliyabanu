<!DOCTYPE html>
<html>
<head>
    <title>Workshop Event Registration</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

<center>

<h1>Python Scripting Web Development Workshop</h1>
<h3>Organized by Computer Application Department</h3>
<hr>

<form id="registrationForm">

    <fieldset>
        <legend>Personal Details</legend>

        <label>Name:</label><br>
        <input type="text" id="name" required><br><br>

        <label>Email:</label><br>
        <input type="email" id="email" required><br><br>

        <label>Phone Number:</label><br>
        <input type="tel" id="phone"><br><br>

        <label>Date of Birth:</label><br>
        <input type="date"><br><br>

        <label>Gender:</label><br>
        <input type="radio" name="gender"> Male
        <input type="radio" name="gender"> Female
        <input type="radio" name="gender"> Other

    </fieldset>

    <br>

    <fieldset>
        <legend>Event Details</legend>

        <label>Event Selection:</label><br>
        <select>
            <option>Python Scripting</option>
            <option>Web Development</option>
            <option>AI Foundations</option>
        </select><br><br>

        <label>Mode of Participation:</label><br>
        <input type="checkbox"> Online
        <input type="checkbox"> Offline

    </fieldset>

    <br>

    <fieldset>
        <legend>Additional Information</legend>

        <label>College / Company Name:</label><br>
        <input type="text"><br><br>

        <label>Upload ID Proof:</label><br>
        <input type="file"><br><br>

        <label>Comments / Expectations:</label><br>
        <textarea rows="4" cols="30"></textarea>

    </fieldset>

    <br>

    <button type="submit">Submit</button>
    <button type="reset">Reset</button>

</form>

<hr>
<p>© 2026 Workshop Event</p>

</center>

<script src="script.js"></script>

</body>
</html>
